{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "declaration": false,
    "removeComments": true,
    "sourceMap": false
  },
  "include": ["src/**/*.ts"]
}
